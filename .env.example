SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=taxshift.co,www.taxshift.co,openskagit.org,www.openskagit.org
CSRF_TRUSTED_ORIGINS=https://taxshift.co,https://www.taxshift.co
DATABASE_URL=
POSTGIS_DATABASE_URL=
NEW_DATABASE_URL=
# Sentry error reporting
SENTRY_DSN=https://843b24f8073e7e113bb67dce9ac479f4@o4511535972941824.ingest.de.sentry.io/4511694126186576
SENTRY_ENVIRONMENT=production
SENTRY_SEND_DEFAULT_PII=true
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_DEBUG_ROUTE=false

# This one deployment serves two separate products/domains — each gets its
# own SITE_URL/from-address so a change to one never silently affects the
# other's email links or sender identity.
# openskagit.org / Parcel Book (opportunity app):
SITE_URL=https://openskagit.org/opportunity
RESEND_FROM_EMAIL=Parcel Book <parcelbook@openskagit.org>
# taxshift.co (taxtool app):
TAXSHIFT_SITE_URL=https://taxshift.co
TAXSHIFT_FROM_EMAIL=TaxShift <notifications@taxshift.co>
TAXSHIFT_TURNSTILE_SITE_KEY=
TAXSHIFT_TURNSTILE_SECRET_KEY=
# Shared Resend account/API key — both openskagit.org and taxshift.co must be
# verified as separate sending domains in the Resend dashboard.
RESEND_API_KEY=

# DuckDB chat — set DUCKDB_USE_POSTGRES=true to query Railway Postgres directly
# (no .duckdb file needed; DATABASE_URL is used automatically)
DUCKDB_USE_POSTGRES=true

# Only needed when DUCKDB_USE_POSTGRES=false (local .duckdb file path)
OPENSKAGIT_DATABASE=instance/openskagit.duckdb

# OpenAI (required for /ask AI analysis)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1
OPPORTUNITY_SEARCH_MODEL=gpt-4.1-mini
OPPORTUNITY_EVALS_LIVE=0
OPPORTUNITY_EVAL_REPAIR_MODEL=gpt-4.1-mini

# Anthropic (required for the regression app's per-neighborhood AI-guided
# model-adjustment step -- run_neighborhood_compliance_loop). Separate
# provider/key from the OpenAI integration above.
ANTHROPIC_API_KEY=sk-ant-...
REGRESSION_AI_MODEL=claude-sonnet-5
REGRESSION_AI_MAX_ROUNDS=3

# Cloudflare R2 parquet data for /opportunity AI search and ParcelBook DuckDB tools
R2_BUCKET=openskagit
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# OpenSkagit remote MCP tools (Cloudflare Worker parcel/GIS/Census/soils context)
OPENSKAGIT_ENABLE_MCP=true
OPENSKAGIT_MCP_URL=https://skagit-agent-worker.ian-larsen-1976.workers.dev/mcp
OPENSKAGIT_MCP_BEARER_TOKEN=
OPENSKAGIT_MCP_TIMEOUT_SECONDS=60
OPENSKAGIT_MCP_SSE_READ_TIMEOUT_SECONDS=60

# Unified OpenSkagit MCP. Stdio is the safe local default.
# For a separate authenticated Railway service, set transport=streamable-http,
# host=0.0.0.0, a 32+ character random token, and the public HTTPS origin.
OPENSKAGIT_UNIFIED_MCP_TRANSPORT=stdio
OPENSKAGIT_UNIFIED_MCP_HOST=127.0.0.1
OPENSKAGIT_UNIFIED_MCP_PORT=8000
OPENSKAGIT_UNIFIED_MCP_PUBLIC_URL=
OPENSKAGIT_UNIFIED_MCP_TOKEN=
OPENSKAGIT_PUBLIC_ORIGIN=https://openskagit.com
OPENSKAGIT_MCP_CONNECTOR_URL=https://openskagit.com/mcp/api/
