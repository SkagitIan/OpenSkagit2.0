# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Workers
ARCGIS_WORKER_URL=https://arcgis-adapter.ian-larsen-1976.workers.dev
WEB_WORKER_URL=https://web-adapter.ian-larsen-1976.workers.dev
NOTIFY_WORKER_URL=https://notify-adapter.ian-larsen-1976.workers.dev

# Notify Worker email provider (free tier at resend.com - 3,000 emails/month)
RESEND_API_KEY=re_...

# SAM.gov (optional - free API key at sam.gov)
SAM_API_KEY=

# D1 (local dev uses sqlite file)
D1_LOCAL_PATH=catalog/local.db

# Production D1 (set by Railway)
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=

# Nightly source verifier
SOURCE_VERIFIER_CONCURRENCY=8
SOURCE_VERIFIER_TEST_PARCEL=P48165
# Comma-separated source IDs for a partial run. Leave blank to verify all active sources.
SOURCE_VERIFIER_SOURCE_IDS=
# Optional webhook. The verifier posts only when failures occur unless alert-on-warning is enabled.
SOURCE_VERIFIER_ALERT_WEBHOOK=
SOURCE_VERIFIER_ALERT_ON_WARNING=false
